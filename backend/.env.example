# ---- Server ----
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:3000

# ---- Database (MongoDB Atlas) ----
# Get this from MongoDB Atlas -> Connect -> Drivers. Include the db name.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/nexton_crm?retryWrites=true&w=majority

# Optional: only needed locally if your network's DNS refuses MongoDB SRV
# lookups (error: querySrv ECONNREFUSED). Not needed on Vercel.
# DNS_SERVERS=8.8.8.8,1.1.1.1

# ---- Auth ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- WhatsApp (pluggable) ----
# provider: stub | meta | twilio | interakt
WHATSAPP_PROVIDER=stub
WHATSAPP_CATALOGUE_URL=https://example.com/nexton-catalogue.pdf
WHATSAPP_PRODUCT_IMAGE_URL=https://example.com/nexton-product.jpg

# Meta WhatsApp Cloud API (when WHATSAPP_PROVIDER=meta)
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_TEMPLATE_NAME=nexton_intro

# Twilio (when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Seed / first admin (used by `npm run seed`) ----
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@nexton.com
SEED_ADMIN_PASSWORD=changeme123
